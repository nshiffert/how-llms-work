---
import LandingLayout from '../layouts/LandingLayout.astro';
import HeroAttentionViz from '../components/islands/HeroAttentionViz.tsx';
import { CATEGORIES, TOPICS, topicsByCategory, type Topic } from '../data/topics';

const ready = TOPICS.filter((t) => t.status === 'ready');
const pct = Math.round((ready.length / TOPICS.length) * 1000) / 10;

const FEATURED_ACCENTS = ['#38D9E6', '#F06EC4'];
const featured = ready.slice(0, 2).map((t, i) => ({ topic: t, accent: FEATURED_ACCENTS[i % FEATURED_ACCENTS.length] }));

const cats = CATEGORIES.map((c, ci) => ({
  index: String(ci + 1).padStart(2, '0'),
  label: c.label,
  blurb: c.blurb,
  topics: topicsByCategory(c.id),
}));

function cardProps(t: Topic) {
  const built = t.status === 'ready';
  return {
    built,
    href: built ? `/topics/${t.slug}` : undefined,
    statusLabel: built ? 'LIVE' : 'PLANNED',
    statusColor: built ? '#38D9E6' : '#6b7080',
    dotStyle: built
      ? 'background:#38D9E6;box-shadow:0 0 8px #38D9E6'
      : 'background:#3a3f4d',
    cardStyle: built
      ? 'border:1px solid rgba(56,217,230,0.32);background:linear-gradient(180deg,rgba(56,217,230,0.05),rgba(13,15,21,0.5))'
      : 'border:1px solid rgba(255,255,255,0.07);background:rgba(255,255,255,0.014)',
  };
}
---

<LandingLayout title="LLM Internals — learn how modern AI actually works">
  <!-- Hero -->
  <section
    class="hl-hero"
    style="display:grid;grid-template-columns:minmax(0,1.05fr) minmax(0,1fr);gap:clamp(28px,5vw,72px);align-items:center;max-width:1240px;margin:0 auto;padding:clamp(48px,8vh,104px) clamp(20px,5vw,56px) clamp(40px,6vh,72px)"
  >
    <div>
      <div
        style="display:inline-flex;align-items:center;gap:9px;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.12em;color:#38D9E6;border:1px solid rgba(56,217,230,0.3);border-radius:100px;padding:6px 13px"
      >
        <span style="width:6px;height:6px;border-radius:50%;background:#38D9E6;box-shadow:0 0 9px #38D9E6;animation:livepulse 1.8s ease-in-out infinite"></span>
        LLM MECHANICS · INTERACTIVE
      </div>
      <h1 style="font-size:clamp(40px,5.4vw,74px);line-height:1.02;font-weight:700;letter-spacing:-0.025em;margin:22px 0 0">
        Learn how modern AI <span style="color:#38D9E6">actually</span> works.
      </h1>
      <p style="font-size:clamp(16px,1.4vw,19px);line-height:1.6;color:#9aa0b0;max-width:540px;margin:22px 0 0">
        From tokenization and attention to sampling, fine-tuning, RAG, and the
        math underneath it all — every topic is visual, interactive, and
        concrete. Work the full set and you'll understand these systems better
        than most people calling themselves experts.
      </p>

      <div style="display:flex;flex-wrap:wrap;gap:14px;margin:30px 0 0">
        <a
          href="/topics/tokenization"
          class="hl-btn-primary"
          style="text-decoration:none;display:inline-flex;align-items:center;gap:9px;background:#38D9E6;color:#06222a;font-weight:600;font-size:15px;padding:13px 22px;border-radius:11px"
        >
          Start with Tokenization <span>→</span>
        </a>
        <a
          href="#curriculum"
          class="hl-btn-ghost"
          style="text-decoration:none;display:inline-flex;align-items:center;gap:9px;color:#e9ebf1;font-weight:500;font-size:15px;padding:13px 22px;border-radius:11px;border:1px solid rgba(255,255,255,0.14)"
        >
          Browse all {TOPICS.length} topics
        </a>
      </div>

      <div style="margin:34px 0 0;max-width:430px">
        <div style="display:flex;justify-content:space-between;font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:#6b7080;margin-bottom:8px">
          <span style="color:#9aa0b0">{ready.length} of {TOPICS.length} built</span>
          <span>{CATEGORIES.length} categories · mechanics-first</span>
        </div>
        <div style="height:5px;border-radius:100px;background:rgba(255,255,255,0.07);overflow:hidden">
          <div style={`height:100%;width:${pct}%;border-radius:100px;background:linear-gradient(90deg,#38D9E6,#F06EC4);box-shadow:0 0 12px rgba(56,217,230,0.6)`}></div>
        </div>
      </div>
    </div>

    <div
      style="position:relative;height:clamp(330px,42vw,480px);border-radius:16px;border:1px solid rgba(255,255,255,0.09);background:linear-gradient(180deg,rgba(18,21,28,0.9),rgba(9,11,16,0.9));overflow:hidden;box-shadow:0 30px 80px -30px rgba(0,0,0,0.8)"
    >
      <HeroAttentionViz client:load />
      <div style="position:absolute;left:16px;bottom:14px;display:flex;align-items:center;gap:8px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:#9aa0b0">
        <span style="width:6px;height:6px;border-radius:50%;background:#38D9E6;box-shadow:0 0 8px #38D9E6;animation:livepulse 1.8s ease-in-out infinite"></span>live
      </div>
      <div style="position:absolute;right:16px;bottom:14px;font-family:'IBM Plex Mono',monospace;font-size:11px;color:#6b7080">self-attention · 1 head</div>
    </div>
  </section>

  <!-- Playable now -->
  <section style="max-width:1240px;margin:0 auto;padding:clamp(28px,4vh,48px) clamp(20px,5vw,56px) clamp(20px,3vh,32px)">
    <div style="display:flex;align-items:baseline;gap:14px;margin-bottom:24px">
      <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.14em;color:#38D9E6">PLAYABLE NOW</span>
      <span style="height:1px;flex:1;background:rgba(255,255,255,0.08)"></span>
      <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#6b7080">{ready.length} interactive demo{ready.length === 1 ? '' : 's'}</span>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(330px,1fr));gap:20px">
      {
        featured.map(({ topic, accent }) => (
          <a
            href={`/topics/${topic.slug}`}
            class="hl-featured"
            style={`--accent:${accent};text-decoration:none;color:inherit;display:flex;flex-direction:column;border-radius:15px;overflow:hidden;border:1px solid ${accent}47;background:linear-gradient(180deg,${accent}0d,rgba(13,15,21,0.6))`}
          >
            <div style="position:relative;aspect-ratio:16/9;overflow:hidden;border-bottom:1px solid rgba(255,255,255,0.06)">
              <div style={`position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:repeating-linear-gradient(135deg,${accent}10 0 2px,transparent 2px 11px),#0a0c12;animation:drift 6s linear infinite`}>
                <span style={`font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.08em;color:${accent};text-align:center;padding:0 20px`}>{topic.viz}</span>
              </div>
              <img
                src={`/images/${topic.slug}-demo.png`}
                onerror="this.style.display='none'"
                style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover"
                alt=""
              />
            </div>
            <div style="padding:20px 22px 22px;display:flex;flex-direction:column;gap:9px">
              <div style="display:flex;align-items:center;gap:8px">
                <span style={`width:7px;height:7px;border-radius:50%;background:${accent};box-shadow:0 0 8px ${accent}`}></span>
                <span style={`font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:0.12em;color:${accent}`}>LIVE · THE BASICS</span>
                <span style={`margin-left:auto;color:${accent};font-size:18px`}>→</span>
              </div>
              <div style="font-size:22px;font-weight:600;letter-spacing:-0.01em">{topic.title}</div>
              <div style="font-size:14px;line-height:1.55;color:#9398a8">{topic.hook}</div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Curriculum -->
  <section id="curriculum" style="max-width:1240px;margin:0 auto;padding:clamp(40px,6vh,72px) clamp(20px,5vw,56px) clamp(60px,9vh,110px)">
    <div style="margin-bottom:40px">
      <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.14em;color:#38D9E6">THE FULL CURRICULUM</span>
      <h2 style="font-size:clamp(28px,3.4vw,42px);font-weight:700;letter-spacing:-0.02em;margin:12px 0 0">
        {TOPICS.length} topics. {CATEGORIES.length} categories. Mechanics first, metaphors second.
      </h2>
    </div>

    {
      cats.map((cat) => (
        <div style="margin-bottom:48px">
          <div class="hl-catrow" style="display:flex;align-items:baseline;gap:16px;margin-bottom:20px;border-top:1px solid rgba(255,255,255,0.08);padding-top:20px">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:13px;color:#38D9E6">{cat.index}</span>
            <h3 style="font-size:23px;font-weight:600;letter-spacing:-0.01em;margin:0;white-space:nowrap">{cat.label}</h3>
            <span style="font-size:14px;color:#7a8094;line-height:1.4">{cat.blurb}</span>
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(282px,1fr));gap:14px">
            {
              cat.topics.map((t) => {
                const p = cardProps(t);
                const Tag = p.built ? 'a' : 'div';
                return (
                  <Tag
                    href={p.href}
                    class={p.built ? 'hl-card' : 'hl-card-planned'}
                    style={`text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:9px;padding:18px;border-radius:13px;min-height:158px;cursor:${p.built ? 'pointer' : 'default'};${p.cardStyle}`}
                  >
                    <div style="display:flex;align-items:center;gap:8px">
                      <span style={`width:7px;height:7px;border-radius:50%;${p.dotStyle}`}></span>
                      <span style={`font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.13em;color:${p.statusColor}`}>{p.statusLabel}</span>
                      {p.built && <span style="margin-left:auto;color:#38D9E6">→</span>}
                    </div>
                    <div style="font-size:18px;font-weight:600;letter-spacing:-0.01em">{t.title}</div>
                    <div style="font-size:13px;line-height:1.5;color:#9398a8">{t.hook}</div>
                    <div style="margin-top:auto;font-family:'IBM Plex Mono',monospace;font-size:11px;color:#6b7080;border-top:1px solid rgba(255,255,255,0.06);padding-top:10px">{t.viz}</div>
                  </Tag>
                );
              })
            }
          </div>
        </div>
      ))
    }
  </section>
</LandingLayout>
