---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Glossary">
  <div class="mx-auto max-w-prose px-5 py-12">
    <h1 class="text-3xl font-bold tracking-tight">Glossary</h1>
    <p class="mt-4 text-lg text-fg-muted">
      A searchable index of terms, each linking back to the topic page where it
      is shown working.
    </p>
    <div class="card mt-8 flex items-center gap-3 p-5 text-sm text-fg-muted">
      <span class="chip">Phase 4</span>
      Built once the topic pages exist — terms are pulled from the pages so the
      glossary stays in sync. Search and cross-links land here.
    </div>
  </div>
</BaseLayout>
