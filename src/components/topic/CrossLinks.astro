---
import { getTopic } from '../../data/topics';
interface Props {
  slugs: string[];
}
const { slugs } = Astro.props;
const links = slugs.map((s) => getTopic(s)).filter((t): t is NonNullable<typeof t> => Boolean(t));
---

{
  links.length > 0 && (
    <section class="border-t border-line py-10">
      <div class="mb-4 flex items-baseline gap-3">
        <span class="font-mono text-xs font-semibold text-fg-faint" aria-hidden="true">→</span>
        <h2 class="text-base font-semibold tracking-tight text-fg-muted">This connects to</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {links.map((t) => {
          const ready = t.status === 'ready';
          const Tag = ready ? 'a' : 'div';
          return (
            <Tag
              href={ready ? `/topics/${t.slug}` : undefined}
              class:list={[
                'card group flex flex-col gap-1 px-4 py-3',
                ready ? 'hover:border-accent/40' : 'cursor-default opacity-60',
              ]}
              style={`--c: var(--cat-${t.category})`}
            >
              <span class="flex items-center gap-2 text-sm font-medium text-fg">
                <span class="h-1.5 w-1.5 rounded-full" style="background: var(--c)" />
                <span class={ready ? 'group-hover:text-accent-hover' : ''}>{t.title}</span>
                {!ready && (
                  <span class="chip border-line/60 !px-1.5 !py-0 text-[0.55rem]">planned</span>
                )}
              </span>
              <span class="line-clamp-2 text-xs text-fg-muted">{t.hook}</span>
            </Tag>
          );
        })}
      </div>
    </section>
  )
}
